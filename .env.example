# FdF — local environment example. Copy to .env.local and fill in real values.
# NEVER commit .env.local (see .gitignore). Production values live in Vercel env vars.

# Supabase (EU region — ADR-0003 §2)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only, Vercel Production env only

# Resend (transactional email)
# RESEND_API_KEY=

# Stripe (beta pricing disabled until ADR-0001 finalization)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Admin panel (HTTP Basic auth on /admin/* and /api/admin/*)
# Username fisso = "fdf" (qualsiasi stringa accettata); password confrontata contro ADMIN_SECRET.
# ADMIN_SECRET=

# Kill-switch toggle — set to "1" to short-circuit /api/* + /api/health to 503
# MAINTENANCE_MODE=

# Ingestion — Gmail OAuth + token encryption (FDFA-30, ADR-0005 opzione D)
# Progetto GCP `fdf-ingestion`, OAuth web client, scope minimo gmail.readonly.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=      # server-only
# GOOGLE_OAUTH_REDIRECT_URI=       # e.g. https://fdf.gargency.com/api/integrations/gmail/callback
# GOOGLE_OAUTH_TEST_MODE=          # set to "1" pre-FDFA-13 per accettare X-FdF-Household-Id/User-Id headers sullo scaffold route

# Master key AES-256 per cifrare refresh/access token at rest (ADR-0003 §3, FDFA-30).
# Generare con: node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
# SUPABASE_INGESTION_KMS_KEY=

# Vercel Cron bearer secret — protegge /api/cron/* da invocazioni non-Vercel
# (FDFA-30 M4d). In prod Vercel setta automaticamente `Authorization: Bearer
# $CRON_SECRET` sulle invocazioni cron. In dev l'header è opzionale.
# CRON_SECRET=
